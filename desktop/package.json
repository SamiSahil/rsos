{
  "name": "restos-desktop",
  "version": "1.0.0",
  "description": "RestOS Desktop App",
  "main": "main.js",
  "type": "module",
 "scripts": {
  "sync:renderer": "node scripts/syncRenderer.js",
  "dev": "npm run sync:renderer && electron .",
  "dist": "npm run sync:renderer && electron-builder"
},
  "build": {
    "appId": "com.restos.app",
    "productName": "RestOS",
    "win": { "target": "nsis", "icon": "assets/icon.ico" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "renderer/**/*",
      "package.json"
    ]
  },
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}